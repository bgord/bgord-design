    "@types/bun": "1.3.11",
    "cspell": "9.7.0",
    "gzip-cli": "1.2.0",
    "knip": "6.0.4",
    "lefthook": "2.1.4",
    "lightningcss-cli": "1.32.0",
    "lockfile-lint": "5.0.0",
    "only-allow": "1.2.2",
    "shellcheck": "4.1.0",
    "typescript": "6.0.2"
  }
