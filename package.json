    "@typescript/native-preview": "7.0.0-dev.20260527.2",
    "cspell": "10.0.1",
    "gzip-cli": "1.2.0",
    "knip": "6.15.0",
    "lefthook": "2.1.9",
    "lightningcss-cli": "1.32.0",
    "lockfile-lint": "5.0.0",
    "only-allow": "1.2.2",
    "shellcheck": "4.1.0",
    "typescript": "6.0.3"
  }
}
